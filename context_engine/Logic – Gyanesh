import datetime
import time
import signal
import sys

class SecurionSystem:
    def __init__(self, frame_threshold=3, cooldown_seconds=10):
        self.frame_threshold = frame_threshold
        self.cooldown_seconds = cooldown_seconds
        self.frame_counter = 0
        self.last_alert_time = 0
        self.running = True
        self.log_history = []
        signal.signal(signal.SIGINT, self.shutdown)

    def shutdown(self, signum, frame):
        print("\nSECURION shutting down...")
        print("Total logs:", len(self.log_history))
        sys.exit(0)

    def calculate_score(self, face_detected, zone, behavior):
        score = 0
        if face_detected:
            score += 50
            if zone == "RESTRICTED": score += 30
            if behavior == "LOITERING": score += 20
        return min(score, 100)

    def evaluate(self, score):
        now = datetime.datetime.now()
        hour = now.hour
        timestamp = now.strftime("%H:%M:%S")

        if score <= 33: risk = "LOW"
        elif score <= 70: risk = "MEDIUM"
        else: risk = "HIGH"

        if 6 <= hour < 18: window = "DAY"
        elif 18 <= hour < 23: window = "EVENING"
        else: window = "LATE NIGHT"

        trigger = False
        status = "SAFE"
        reason = "Normal"

        if risk == "HIGH":
            trigger = True
            status = "CRITICAL"
            reason = "High Risk Detected"
        elif window == "LATE NIGHT" and score > 15:
            trigger = True
            status = "CRITICAL"
            reason = "Night Suspicion"
        elif risk == "MEDIUM":
            status = "LOG_ONLY"
            reason = "Minor Activity Logged"

        return {
            "timestamp": timestamp, "score": score, "risk": risk,
            "window": window, "trigger": trigger, "status": status, "reason": reason
        }

    def process_frame(self, face_detected, zone, behavior):
        score = self.calculate_score(face_detected, zone, behavior)
        result = self.evaluate(score)

        # Frame counter logic (Day 22)
        if result["trigger"] or result["status"] == "LOG_ONLY":
            self.frame_counter += 1
        else:
            self.frame_counter = 0

        cooldown_active = (time.time() - self.last_alert_time) < self.cooldown_seconds
        alarm = "STANDBY"

        # FIXED LOGIC: Reset counter properly after reaching threshold
        if self.frame_counter >= self.frame_threshold:
            if result["trigger"]:
                if not cooldown_active:
                    alarm = "🚨 ALERT"
                    self.last_alert_time = time.time()
                    self.frame_counter = 0 # RESET AFTER ALERT
                else:
                    alarm = "⏳ COOLDOWN"
                    self.frame_counter = 0 # RESET EVEN IN COOLDOWN TO RE-START COUNT
            
            elif result["status"] == "LOG_ONLY":
                alarm = "📝 LOGGED"
                self.log_history.append(result)
                self.frame_counter = 0 # RESET AFTER LOGGING

        result["frames"] = self.frame_counter
        result["alarm"] = alarm
        return result

    def run(self):
        print("\n===============================")
        print("  SECURION MASTER ENGINE LIVE  ")
        print("===============================\n")
        while self.running:
            # Simulation Input
            result = self.process_frame(face_detected=True, zone="RESTRICTED", behavior="LOITERING")
            
            print(f"[{result['timestamp']}] Score: {result['score']}% | Risk: {result['risk']}")
            print(f"Frames: {result['frames']}/{self.frame_threshold} | Alarm: {result['alarm']}")
            print(f"Reason: {result['reason']}")
            print("-" * 32)
            time.sleep(1)

if __name__ == "__main__":
    system = SecurionSystem(frame_threshold=3, cooldown_seconds=10)
    system.run()

