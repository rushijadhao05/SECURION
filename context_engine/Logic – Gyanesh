import datetime

def calculate_securion_score(face_detected, zone, behavior):
    """
    Contextual Scoring: Face, Zone, and Behavior integration.
    """
    score = 0
    if face_detected:
        score += 50  # Base match score
        if zone == "RESTRICTED":
            score += 30  # Location penalty
        if behavior == "LOITERING":
            score += 20  # Behavioral penalty
    
    return min(score, 100)

def evaluate_risk_status(score):
    """
    Final Decision Engine based on Time-Windows and Risk Thresholds.
    """
    now = datetime.datetime.now()
    current_hour = now.hour
    current_time = now.strftime("%H:%M:%S")

    # 1. Score Classification (Standard 100/3 Scale)
    if score <= 33.33:
        score_level = "LOW"
    elif score <= 66.66:
        score_level = "MEDIUM"
    else:
        score_level = "HIGH"

    # 2. Time-Window Classification
    if 6 <= current_hour < 18:
        time_level = "LOW (Day)"
    elif 18 <= current_hour < 23:
        time_level = "MEDIUM (Evening)"
    else:
        time_level = "HIGH (Late Night)"

    # 3. Decision Logic
    trigger_alarm = False
    status = "SAFE"
    reason = "Standard Activity"

    # Condition A: Absolute High Risk
    if score_level == "HIGH":
        status = "CRITICAL"
        trigger_alarm = True
        reason = "Critical Risk Score (>66.66)"

    # Condition B: High-Sensitivity Night Mode
    elif time_level == "HIGH (Late Night)" and score > 15:
        status = "CRITICAL"
        trigger_alarm = True
        reason = "Suspicious Night Movement (Score > 15)"

    # Condition C: Evening Warning
    elif time_level == "MEDIUM (Evening)" and score_level == "MEDIUM":
        status = "WARNING"
        trigger_alarm = True
        reason = "Unusual Evening Activity"

    return {
        "Timestamp": current_time,
        "Risk_Score": f"{score}%",
        "Risk_Level": score_level,
        "Time_Window": time_level,
        "System_Status": status,
        "Alarm": "🚨 ACTIVE" if trigger_alarm else "✅ STANDBY",
        "Analysis": reason
    }

# --- TEST EXECUTION ---
if __name__ == "__main__":
    # Example Scenario
    current_score = calculate_securion_score(face_detected=True, zone="RESTRICTED", behavior="LOITERING")
    report = evaluate_risk_status(current_score)

